{
  "manifest_version": 3,
  "name": "Saral AI",
  "version": "1.0",
  "description": "Making the web simple, accessible, and distraction-free.",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://*.google.com/*",
        "*://*.search.brave.com/*",
        "*://*.bing.com/*",
        "*://*.duckduckgo.com/*"
      ],
      "js": [
        "core/helpers.js",
        "core/cls.js",
        "core/theme.js",
        "core/adaptive.js",
        "core/speech.js",
        "core/overlay.js",
        "core/reader-mode.js",
        "content.js"
      ],
      "css": ["styles.css"]
    }
  ]
}