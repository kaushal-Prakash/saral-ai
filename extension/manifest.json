{
  "manifest_version": 3,
  "name": "Saral AI",
  "version": "1.0",
  "description": "Simplify the web for every mind",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["core.js"]
    }
  ]
}
